<div class="mb-4 px-2" id="post_<%= post.id %>_container"> 
  <% if current_user.present? %>
    <% if current_user.voted_up_on? post %>
      <%= link_to post_downvotes_path(post.id), data: { turbo_method: :post }, class: "inline-flex items-center space-x-1 text-red-600 hover:text-red-700" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="red" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        <span><%= pluralize post.get_likes.size, "like" %></span>
      <% end %>
    <% else %>
      <%= link_to post_upvotes_path(post), data: { turbo_method: :post }, class: "inline-flex items-center space-x-1 text-gray-600 hover:text-blue-600" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        <span><%= pluralize post.get_likes.size, "like" %></span>
      <% end %>
    <% end %>
  <% else %>
    <div class="inline-flex items-center space-x-1 text-gray-400">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
      <span><%= pluralize post.get_likes.size, "like" %></span>
    </div>
  <% end %>
</div>
